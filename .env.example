# Copy to .env and fill in. Variables already exported in the shell take
# precedence over values defined here.

# Temporal server address. Default: localhost:7233
TEMPORAL_ADDRESS=localhost:7233

# Base directory for per-run workspaces and the imports/ drop zone.
# Default: /tmp/decanter
DECANTER_WORKSPACE_PATH=./workspace

# Reference image for bumper dHash verification. Default: assets/bumper_reference.png
DECANTER_BUMPER_REF_IMAGE=assets/bumper_reference.png

# Directory containing Python scripts (detect_bumpers.py, transcribe.py).
# Default: scripts
DECANTER_SCRIPT_DIR=scripts

# Intro/outro video assets, concatenated into Assemble output.
DECANTER_INTRO_VIDEO=assets/intro.m4v
DECANTER_OUTRO_VIDEO=assets/outro.m4v

# Groq Cloud API key — required. Transcribe activity calls whisper-large-v3.
GROQ_API_KEY=

# YouTube OAuth refresh-token creds minted by `go run ./cmd/yt-auth`.
# Required by the Upload activity; warning-only at worker startup so the
# worker still runs for pipelines that stop at the upload gate.
DECANTER_YOUTUBE_CREDS_FILE=
